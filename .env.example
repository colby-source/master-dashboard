# ── Server ───────────────────────────────────────────────
PORT=3001
DB_PATH=./data/master-dashboard.db
DASHBOARD_API_KEY=              # REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))". When unset in dev, /api routes are open (warn logged).

# ── GHL (GoHighLevel) ───────────────────────────────────
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_KEY=                    # Grand Park Capital
GHL_LOCATION_ID=
GHL_API_KEY_BNN=                # Brand New Now
GHL_LOCATION_ID_BNN=
GHL_API_KEY_TIKKUN=             # Tikkun
GHL_LOCATION_ID_TIKKUN=

# ── Instantly (Cold Email) ──────────────────────────────
INSTANTLY_API_KEY=

# ── Meta / Facebook ─────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── WhatsApp Business ───────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=master-dashboard-wa-hook

# ── AI / Enrichment ─────────────────────────────────────
ANTHROPIC_API_KEY=
PDL_API_KEY=                    # People Data Labs
PDL_BASE_URL=https://api.peopledatalabs.com/v5
HUNTER_API_KEY=                 # Hunter.io
HUNTER_BASE_URL=https://api.hunter.io/v2
ANYMAILFINDER_API_KEY=          # Anymailfinder.com
FINDYMAIL_API_KEY=               # Findymail.com — cascade after AMF misses
ENRICHMENT_AUTO_ENABLED=true
ENRICHMENT_STALE_DAYS=90

# ── Apify ───────────────────────────────────────────────
APIFY_API_KEY=
# Dev-only: bypass TLS cert validation for api.apify.com when a local proxy /
# antivirus / VPN is MITM-ing HTTPS. NEVER enable in production. See CLAUDE.md.
APIFY_ALLOW_INSECURE_TLS=false

# ── eBay (optional — Equipment Finder Browse API) ───────
# If unset, Equipment Finder falls back to HTML scraping.
EBAY_APP_ID=
EBAY_CERT_ID=

# ── OpenClaw ────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://192.168.1.220:18789
OPENCLAW_TOKEN=

# ── N8N ─────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# ── Webhook Secrets (HMAC verification) ─────────────────
RB2B_WEBHOOK_SECRET=
GHL_WEBHOOK_SECRET=
META_WEBHOOK_SECRET=
INSTANTLY_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET=
# GPF-II reply-ops HMAC secret (generate: openssl rand -hex 32)
GPF2_OPS_SECRET=
# GPC public form intake — HMAC-SHA256 shared secret used by the GPC
# marketing site (graniteparkcapitalfund.com) to sign data-room form
# POSTs to /api/gpc-public/data-room-submit. The same value MUST be
# set as VITE_GPC_FORM_SHARED_SECRET on the Cloudflare Pages env vars
# for the GPC site. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GPC_FORM_SHARED_SECRET=
# Public base URL for Telegram URL-button callbacks (Cloudflare tunnel or Railway URL)
PUBLIC_BASE_URL=http://localhost:3001
# Generic webhook signing fallback
WEBHOOK_SECRET=

# ── Telegram Notifications ─────────────────────────────
TELEGRAM_BOT_TOKEN=             # @colbymacminibot token from BotFather
TELEGRAM_CHAT_ID=               # Colby's chat ID (default recipient)
TELEGRAM_CHAT_ID_BMN=           # Ryan's chat ID (BMN operator)

# ── Competitors ─────────────────────────────────────────
COMPETITOR_URLS=                # Comma-separated URLs

# ── Sync ────────────────────────────────────────────────
SYNC_INTERVAL_MS=60000

# ── Brand Launchpad ─────────────────────────────────────
# Google Drive OAuth (for client asset uploads to BMN/Clients/{brand}/).
# Setup once via https://developers.google.com/oauthplayground — request scope
# https://www.googleapis.com/auth/drive.file, then exchange code for refresh token.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
# Drive folder ID for "BMN > Clients" — find it in the URL of that folder.
GOOGLE_DRIVE_BMN_CLIENTS_ROOT_FOLDER_ID=
# Sender for client-facing magic-link emails (must be a valid Instantly sender).
LAUNCHPAD_FROM_EMAIL=colby@brandmenow.co
LAUNCHPAD_MAGIC_LINK_TTL_DAYS=7
LAUNCHPAD_MAX_ASSET_SIZE_MB=50
